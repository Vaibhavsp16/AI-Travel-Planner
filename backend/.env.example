# Server Port
PORT=5000

# MongoDB URI (Optional: If omitted, the system will fall back to local JSON database storage under backend/.data/)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/travel-planner?retryWrites=true&w=majority

# JWT Token Secret Key
JWT_SECRET=your_jwt_secret_key_goes_here

# Gemini API Key (Optional: If omitted, the system will run in offline mode using a smart local mock generator)
GEMINI_API_KEY=your_gemini_api_key_goes_here
